<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main>
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-content">
        <h1>İletişim</h1>
        <div class="breadcrumb">
          <a href="/">Ana Sayfa</a> / <span>İletişim</span>
        </div>
      </div>
    </div>
  </section>

  <section class="contact section">
    <div class="container">
      <!-- Success alert -->
      <% if (success) { %>
      <div class="alert alert-success">
        <i data-lucide="check-circle" style="width:24px;height:24px;"></i>
        <div>
          <strong>Mesajınız alındı!</strong>
          <p>En kısa sürede size dönüş yapacağız. Teşekkür ederiz.</p>
        </div>
        <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
      </div>
      <% } %>

      <!-- Error alert -->
      <% if (error) { %>
      <div class="alert alert-error">
        <i data-lucide="alert-circle" style="width:24px;height:24px;"></i>
        <div>
          <strong>Hata!</strong>
          <p><%= error %></p>
        </div>
        <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
      </div>
      <% } %>

      <div class="section-header center">
        <span class="section-tag">İletişim</span>
        <h2 class="section-title">Bize Ulaşın</h2>
        <p class="section-subtitle">Randevu ve tüm sorularınız için aşağıdaki formu doldurun.</p>
      </div>
      <div class="contact-wrapper">
        <div class="contact-info">
          <div class="contact-card glass-card">
            <div class="contact-card-bg"></div>
            <i data-lucide="map-pin" style="width:28px;height:28px;"></i>
            <h4>Adres</h4>
            <p><%= site.address %></p>
          </div>
          <div class="contact-card glass-card">
            <div class="contact-card-bg"></div>
            <i data-lucide="phone" style="width:28px;height:28px;"></i>
            <h4>Telefon</h4>
            <p><a href="tel:<%= site.phone.replace(/[^0-9+]/g, '') %>" style="color:inherit"><%= site.phone %></a></p>
          </div>
          <div class="contact-card glass-card">
            <div class="contact-card-bg"></div>
            <i data-lucide="mail" style="width:28px;height:28px;"></i>
            <h4>E-posta</h4>
            <p><a href="mailto:<%= site.email %>" style="color:inherit"><%= site.email %></a></p>
          </div>
          <div class="contact-card glass-card">
            <div class="contact-card-bg"></div>
            <i data-lucide="clock" style="width:28px;height:28px;"></i>
            <h4>Çalışma Saatleri</h4>
            <p><%= site.workingHours %></p>
          </div>
          <div class="contact-map">
            <a href="https://www.google.com/maps/place/Diyetisyen+Fulya+Sar%C4%B1+Sa%C4%9Fl%C4%B1kl%C4%B1+Ya%C5%9Fam+ve+Diyet+Dan%C4%B1%C5%9Fmanl%C4%B1%C4%9F%C4%B1/@36.8921142,30.6723821,17z/data=!3m1!4b1!4m6!3m5!1s0x14c391af3496843f:0x301e0f8dcd9acd69!8m2!3d36.8921099!4d30.674957!16s%2Fg%2F11sb0l8yl8?hl=tr-TR" target="_blank" rel="noopener" class="btn btn-outline" style="width:100%;justify-content:center;"><i data-lucide="map-pin" style="width:16px;height:16px;"></i> Google Haritalar'da Aç</a>
          </div>
        </div>
        <form class="contact-form" action="/iletisim" method="POST" novalidate>
          <div class="form-shine"></div>
          <div class="form-row">
            <div class="form-group">
              <label for="contact-name" class="form-label">Adınız Soyadınız <span class="required">*</span></label>
              <input type="text" id="contact-name" name="name" placeholder="Adınız Soyadınız" required minlength="2" autocomplete="name">
              <span class="form-error">Lütfen adınızı girin (en az 2 karakter)</span>
            </div>
            <div class="form-group">
              <label for="contact-email" class="form-label">E-posta Adresiniz <span class="required">*</span></label>
              <input type="email" id="contact-email" name="email" placeholder="ornek@mail.com" required autocomplete="email">
              <span class="form-error">Geçerli bir e-posta adresi giriniz</span>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="contact-phone" class="form-label">Telefon Numaranız</label>
              <input type="tel" id="contact-phone" name="phone" placeholder="0532 123 45 67" autocomplete="tel">
              <span class="form-error">Geçerli bir telefon numarası giriniz</span>
            </div>
            <div class="form-group">
              <label for="contact-service" class="form-label">Hizmet Seçiniz</label>
              <select id="contact-service" name="service">
                <option value="">Hizmet Seçiniz</option>
                <option>Kişisel Diyet Programı</option>
                <option>Hastalık Diyeti</option>
                <option>Gebelik Beslenmesi</option>
                <option>Sporcu Beslenmesi</option>
                <option>Detoks Programı</option>
                <option>Diğer</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="contact-message" class="form-label">Mesajınız</label>
            <textarea id="contact-message" name="message" rows="5" placeholder="Mesajınızı buraya yazın..." maxlength="2000"></textarea>
            <span class="form-error">Mesaj çok uzun (max 2000 karakter)</span>
          </div>
          <button type="submit" class="btn btn-primary btn-block"><span>Mesajı Gönder</span></button>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
