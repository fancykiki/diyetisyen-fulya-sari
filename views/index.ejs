<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="scroll-progress" id="scrollProgress"></div>

<% if (success) { %>
<div class="toast toast-success" id="formSuccess">
  <i data-lucide="check-circle" style="width:20px;height:20px;"></i>
  <span>Mesajınız başarıyla gönderildi! En kısa sürede size dönüş yapacağız.</span>
  <button class="toast-close" onclick="this.parentElement.remove()">&times;</button>
</div>
<% } %>

<main>
  <!-- HERO SLIDER -->
  <section class="hero" id="hero">
    <div class="hero-slider" id="heroSlider">
      <% slider.forEach((slide, index) => { %>
      <div class="hero-slide<% if(index === 0) { %> active<% } %>">
        <div class="hero-slide-bg" style="background-image: url('<%= slide.image %>');"></div>
        <div class="hero-slide-vignette" aria-hidden="true"></div>
        <div class="hero-cinematic-grain" aria-hidden="true"></div>
        <div class="hero-overlay"></div>
        <div class="container">
          <div class="hero-content">
            <div class="hero-panel">
              <div class="hero-panel-shine" aria-hidden="true"></div>
              <div class="hero-panel-edge" aria-hidden="true"></div>
              <div class="hero-panel-pattern"></div>
              <div class="hero-panel-orbit"></div>
              <div class="hero-panel-inner">
              <div class="hero-panel-tag"><%= slide.tag || 'DİYETİSYEN FULYA SARI' %></div>
              <h1 class="hero-panel-title"><%= slide.title %></h1>
              <p class="hero-panel-desc"><%= slide.subtitle %></p>
              <div class="hero-features">
                <% slide.features.forEach(f => { %>
                <div class="hero-feature hero-feature-<%= f.color %>">
                  <div class="hero-feature-icon">
                     <% if (f.icon === 'apple') { %>
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 6C12 3 14.5 1.5 16.5 2.5C17.5 3 17.5 5.5 15.5 6.5C14.5 7 13 6.5 12 6Z" fill="url(#leafGrad)" />
                        <path d="M12 7C11.5 5.5 12 4.5 12.5 3.5" stroke="#B94F43" stroke-width="1.5" stroke-linecap="round" />
                        <path d="M12 7.5C10.5 7.5 9 6.5 7 6.5C4 6.5 2 9 2 12.5C2 17 6.5 21.5 12 22C17.5 21.5 22 17 22 12.5C22 9 20 6.5 17 6.5C15 6.5 13.5 7.5 12 7.5Z" fill="url(#appleGrad)" />
                        <path d="M6 10C5.5 11 5.5 12.5 6 13.5C6.2 14 5.8 14.5 5.3 14.3C4.6 14 4.2 13 4.2 12C4.2 10.5 4.8 9.5 5.5 9.1C6 8.9 6.3 9.4 6 10Z" fill="#FFFFFF" opacity="0.4" />
                        <defs>
                          <linearGradient id="appleGrad" x1="2" y1="6.5" x2="22" y2="22" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#D96C5F" /><stop offset="100%" stop-color="#B94F43" /></linearGradient>
                          <linearGradient id="leafGrad" x1="12" y1="1.5" x2="17.5" y2="6.5" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#F8E1DD" /><stop offset="100%" stop-color="#D96C5F" /></linearGradient>
                        </defs>
                      </svg>
                    <% } else if (f.icon === 'clipboard-list') { %>
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="4" y="3" width="16" height="18" rx="3" fill="url(#boardGrad)" />
                        <rect x="6" y="6" width="12" height="13" rx="1.5" fill="#FFFFFF" />
                        <rect x="8" y="9" width="8" height="1.5" rx="0.75" fill="#EDE7DE" />
                        <rect x="10" y="12" width="6" height="1.5" rx="0.75" fill="#EDE7DE" />
                        <rect x="10" y="15" width="6" height="1.5" rx="0.75" fill="#EDE7DE" />
                        <circle cx="8" cy="12.75" r="1.25" fill="#C99A4A" />
                        <circle cx="8" cy="15.75" r="1.25" fill="#C99A4A" />
                        <path d="M9 2H15V4H9V2Z" fill="url(#clipGrad)" />
                        <rect x="10" y="3.5" width="4" height="1" rx="0.5" fill="#9A7130" />
                        <defs>
                          <linearGradient id="boardGrad" x1="4" y1="3" x2="20" y2="21" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#C99A4A" /><stop offset="100%" stop-color="#9A7130" /></linearGradient>
                          <linearGradient id="clipGrad" x1="9" y1="2" x2="15" y2="4" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#F4E6CA" /><stop offset="100%" stop-color="#C99A4A" /></linearGradient>
                        </defs>
                      </svg>
                    <% } else if (f.icon === 'laptop') { %>
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="4" y="4" width="16" height="11" rx="2" fill="#2C2822" />
                        <rect x="5.5" y="5.5" width="13" height="8" rx="0.5" fill="url(#screenGrad)" />
                        <circle cx="12" cy="8.5" r="2" fill="#FFFFFF" opacity="0.8" />
                        <path d="M9 12.5C9 11 10.3 10.5 12 10.5C13.7 10.5 15 11 15 12.5" fill="#FFFFFF" opacity="0.8" />
                        <path d="M2 16.5C2 15.7 2.7 15 3.5 15H20.5C21.3 15 22 15.7 22 16.5V17C22 18.1 21.1 19 20 19H4C2.9 19 2 18.1 2 17V16.5Z" fill="url(#baseGrad)" />
                        <rect x="10" y="15" width="4" height="1" rx="0.5" fill="#1E3328" />
                        <defs>
                          <linearGradient id="screenGrad" x1="5.5" y1="5.5" x2="18.5" y2="13.5" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#8DC0CD" /><stop offset="100%" stop-color="#4F94A5" /></linearGradient>
                          <linearGradient id="baseGrad" x1="2" y1="15" x2="22" y2="19" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#DDEFF3" /><stop offset="100%" stop-color="#C8DDE3" /></linearGradient>
                        </defs>
                      </svg>
                    <% } else if (f.icon === 'scale') { %>
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="3" width="18" height="18" rx="3" fill="url(#scaleGrad)" stroke="url(#scaleBorder)" stroke-width="1.5" />
                        <rect x="5" y="6" width="3" height="12" rx="1.5" fill="#EDE7DE" />
                        <rect x="16" y="6" width="3" height="12" rx="1.5" fill="#EDE7DE" />
                        <rect x="9" y="5" width="6" height="3" rx="1" fill="#2C2822" />
                        <rect x="10.5" y="6" width="3" height="1" rx="0.5" fill="#D96C5F" />
                        <defs>
                          <linearGradient id="scaleGrad" x1="3" y1="3" x2="21" y2="21" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#F8E1DD" /><stop offset="100%" stop-color="#FFFDF8" /></linearGradient>
                          <linearGradient id="scaleBorder" x1="3" y1="3" x2="21" y2="21" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#D96C5F" /><stop offset="100%" stop-color="#B94F43" /></linearGradient>
                        </defs>
                      </svg>
                    <% } else if (f.icon === 'utensils-crossed') { %>
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <g transform="rotate(45 12 12)">
                          <path d="M12 4C10.5 4 9.5 5.5 9.5 7.5C9.5 9.5 10.5 11 12 11C13.5 11 14.5 9.5 14.5 7.5C14.5 5.5 13.5 4 12 4Z" fill="url(#spoonGrad)" />
                          <rect x="11.25" y="11" width="1.5" height="9" rx="0.75" fill="url(#handleGrad)" />
                        </g>
                        <g transform="rotate(-45 12 12)">
                          <path d="M12 11C13.5 11 14.5 9.5 14.5 7.5V4H13.25V7.5C13.25 8.5 12.75 9 12 9C11.25 9 10.75 8.5 10.75 7.5V4H9.5V7.5C9.5 9.5 10.5 11 12 11Z" fill="url(#forkGrad)" />
                          <rect x="11.35" y="4" width="1.3" height="4.5" fill="url(#forkGrad)" />
                          <rect x="11.25" y="11" width="1.5" height="9" rx="0.75" fill="url(#handleGrad)" />
                        </g>
                        <defs>
                          <linearGradient id="spoonGrad" x1="9.5" y1="4" x2="14.5" y2="11" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#C99A4A" /><stop offset="100%" stop-color="#9A7130" /></linearGradient>
                          <linearGradient id="forkGrad" x1="9.5" y1="4" x2="14.5" y2="11" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#9A7130" /><stop offset="100%" stop-color="#7A5B30" /></linearGradient>
                          <linearGradient id="handleGrad" x1="11.25" y1="11" x2="12.75" y2="20" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#DDBA7A" /><stop offset="100%" stop-color="#9A7130" /></linearGradient>
                        </defs>
                      </svg>
                    <% } else if (f.icon === 'user-check') { %>
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="10" cy="8" r="4" fill="url(#userGrad)" />
                        <path d="M4 18C4 15.2 6.8 14 10 14C11.5 14 12.8 14.3 13.8 14.8" stroke="url(#userGrad)" stroke-width="2" stroke-linecap="round" />
                        <circle cx="17" cy="17" r="5" fill="#FFFFFF" />
                        <circle cx="17" cy="17" r="4" fill="#4F94A5" />
                        <path d="M15.5 17L16.5 18L18.5 16" stroke="#FFFFFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <defs>
                          <linearGradient id="userGrad" x1="4" y1="4" x2="15" y2="18" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#8DC0CD" /><stop offset="100%" stop-color="#4F94A5" /></linearGradient>
                        </defs>
                      </svg>
                    <% } else if (f.icon === 'calendar') { %>
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="4" width="18" height="17" rx="3" fill="#FFFDF8" stroke="#E2D9CE" stroke-width="1.5" />
                        <path d="M3 7C3 5.3 4.3 4 6 4H18C19.7 4 21 5.3 21 7V9H3V7Z" fill="url(#calHeaderGrad)" />
                        <rect x="7" y="2" width="2" height="4" rx="1" fill="#6B6258" />
                        <rect x="15" y="2" width="2" height="4" rx="1" fill="#6B6258" />
                        <rect x="6" y="12" width="2" height="2" rx="0.5" fill="#EDE7DE" />
                        <rect x="11" y="12" width="2" height="2" rx="0.5" fill="#EDE7DE" />
                        <rect x="16" y="12" width="2" height="2" rx="0.5" fill="#EDE7DE" />
                        <rect x="6" y="16" width="2" height="2" rx="0.5" fill="#EDE7DE" />
                        <rect x="11" y="16" width="2" height="2" rx="0.5" fill="#C99A4A" />
                        <rect x="16" y="16" width="2" height="2" rx="0.5" fill="#EDE7DE" />
                        <defs>
                          <linearGradient id="calHeaderGrad" x1="3" y1="4" x2="21" y2="9" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#C99A4A" /><stop offset="100%" stop-color="#9A7130" /></linearGradient>
                        </defs>
                      </svg>
                    <% } else if (f.icon === 'heart-pulse') { %>
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 21.35L10.55 20.03C5.4 15.36 2 12.28 2 8.5C2 5.42 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.09C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.42 22 8.5C22 12.28 18.6 15.36 13.45 20.04L12 21.35Z" fill="url(#heartGrad)" />
                        <path d="M4 10H8.5L9.5 7.5L11 13.5L12.5 6L13.5 11.5L14.5 10H19" stroke="#FFFFFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                        <defs>
                          <linearGradient id="heartGrad" x1="2" y1="3" x2="22" y2="21" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#D96C5F" /><stop offset="100%" stop-color="#B94F43" /></linearGradient>
                        </defs>
                      </svg>
                    <% } else { %>
                      <i data-lucide="<%= f.icon %>"></i>
                    <% } %>
                  </div>
                  <span class="hero-feature-label"><%= f.label %></span>
                </div>
                <% }); %>
              </div>
              <div class="hero-actions">
                <a href="<%= slide.ctaLink %>" class="btn btn-primary"><%= slide.ctaText %></a>
                <a href="<%= slide.ctaSecondaryLink %>" class="btn btn-outline hero-btn-outline"><%= slide.ctaSecondaryText %></a>
              </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>

    <div class="slider-progress"><div class="slider-progress-bar" id="sliderProgressBar"></div></div>

    <div class="slider-counter" id="sliderCounter">
      <span class="slider-counter-current" id="sliderCounterCurrent">01</span>
      <span class="slider-counter-line"></span>
      <span class="slider-counter-total"><%= String(slider.length).padStart(2, '0') %></span>
    </div>

    <div class="slider-controls">
      <div class="slider-ui-shell">
      <button class="slider-btn prev" id="sliderPrev" aria-label="Önceki"><i data-lucide="chevron-left" style="width:16px;height:16px;"></i></button>
      <div class="slider-dots" id="sliderDots">
        <% slider.forEach((_, index) => { %>
        <span class="dot<% if(index === 0) { %> active<% } %>" data-index="<%= index %>"></span>
        <% }); %>
      </div>
      <button class="slider-btn next" id="sliderNext" aria-label="Sonraki"><i data-lucide="chevron-right" style="width:16px;height:16px;"></i></button>
      </div>
    </div>

    <div class="slider-paused-indicator" id="sliderPausedIndicator">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="6" y="4" width="4" height="16"></rect>
        <rect x="14" y="4" width="4" height="16"></rect>
      </svg>
    </div>

    <a href="#introSection" class="hero-scroll-indicator" aria-label="Sonraki bölüme kaydır">
      <span>Aşağı Kaydır</span>
      <div class="scroll-mouse"><div class="scroll-dot"></div></div>
    </a>
  </section>

  <!-- PREMIUM INTRO / MANIFESTO -->
  <section class="intro-section" id="introSection">
    <div class="intro-bg-glow"></div>

    <!-- Floating decorative elements -->
    <div class="intro-float intro-float-1" aria-hidden="true">
      <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M60 16C54 10 46 7 39 7C30 7 24 12 24 20C24 34 38 42 60 44C82 42 96 34 96 20C96 12 90 7 81 7C74 7 66 10 60 16Z" fill="url(#iaGrad)" opacity="0.30"/>
        <path d="M28 38C18 48 16 64 18 82C20 100 36 112 60 114C84 112 100 100 102 82C104 64 102 48 92 38C82 28 70 23 60 21C50 23 38 28 28 38Z" fill="url(#iaGrad)" opacity="0.18"/>
        <circle cx="60" cy="80" r="14" fill="url(#iaGrad)" opacity="0.15"/>
        <path d="M60 21C56 16 48 12 41 11L43 17C48 18 54 21 56 25" fill="url(#igGrad)" opacity="0.30"/>
        <path d="M60 21C66 12 76 7 84 7L82 13C76 14 68 18 64 25" fill="url(#igGrad)" opacity="0.30"/>
        <defs>
          <linearGradient id="iaGrad" x1="18" y1="7" x2="102" y2="114"><stop offset="0%" stop-color="#D96C5F"/><stop offset="100%" stop-color="#B94F43"/></linearGradient>
          <linearGradient id="igGrad" x1="41" y1="7" x2="84" y2="25"><stop offset="0%" stop-color="#315C45"/><stop offset="100%" stop-color="#4A7A5C"/></linearGradient>
        </defs>
      </svg>
    </div>
    <div class="intro-float intro-float-2" aria-hidden="true">
      <svg viewBox="0 0 140 140" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="70" cy="70" r="54" stroke="url(#ringGrad)" stroke-width="1.2" opacity="0.25"/>
        <circle cx="70" cy="70" r="38" stroke="url(#ringGrad)" stroke-width="0.8" opacity="0.18" stroke-dasharray="4 6"/>
        <circle cx="70" cy="70" r="12" fill="url(#ringGrad)" opacity="0.20"/>
        <circle cx="70" cy="70" r="4" fill="url(#ringGrad)" opacity="0.35"/>
        <defs>
          <linearGradient id="ringGrad" x1="16" y1="16" x2="124" y2="124"><stop offset="0%" stop-color="#D96C5F"/><stop offset="50%" stop-color="#C99A4A"/><stop offset="100%" stop-color="#4F94A5"/></linearGradient>
        </defs>
      </svg>
    </div>
    <div class="intro-float intro-float-3" aria-hidden="true">
      <svg viewBox="0 0 110 110" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M55 96C55 96 88 64 90 38C92 16 76 10 66 12C56 14 48 22 46 28C42 20 30 12 20 14C10 16 4 28 6 40C8 56 24 72 55 96Z" fill="url(#lfGrad)" opacity="0.22"/>
        <path d="M55 96C55 96 80 46 82 26" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.20"/>
        <path d="M30 34C30 34 38 18 50 14" stroke="var(--color-sage)" stroke-width="1.2" stroke-linecap="round" opacity="0.15"/>
        <defs>
          <linearGradient id="lfGrad" x1="10" y1="10" x2="55" y2="96"><stop offset="0%" stop-color="#4F7A5E"/><stop offset="100%" stop-color="#315C45"/></linearGradient>
        </defs>
      </svg>
    </div>
    <div class="intro-float intro-float-4" aria-hidden="true">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="40" stroke="url(#seedGrad)" stroke-width="0.8" opacity="0.20"/>
        <circle cx="35" cy="40" r="5" fill="url(#seedGrad)" opacity="0.22"/>
        <circle cx="65" cy="38" r="4" fill="url(#seedGrad)" opacity="0.18"/>
        <circle cx="50" cy="58" r="6" fill="url(#seedGrad)" opacity="0.25"/>
        <circle cx="42" cy="52" r="3" fill="url(#seedGrad)" opacity="0.15"/>
        <circle cx="58" cy="54" r="3.5" fill="url(#seedGrad)" opacity="0.20"/>
        <circle cx="50" cy="68" r="2.5" fill="url(#seedGrad)" opacity="0.15"/>
        <defs>
          <linearGradient id="seedGrad" x1="16" y1="16" x2="84" y2="84"><stop offset="0%" stop-color="#C99A4A"/><stop offset="50%" stop-color="#D96C5F"/><stop offset="100%" stop-color="#4F7A5E"/></linearGradient>
        </defs>
      </svg>
    </div>

    <div class="container">
      <div class="intro-inner">
        <div class="intro-content">
          <span class="intro-badge reveal-up">
            <span class="intro-badge-dot"></span>
            KİŞİYE ÖZEL BESLENME YAKLAŞIMI
          </span>

          <h2 class="intro-title reveal-up">
            Size Uygun Beslenme<br>
            Modelini <span class="intro-title-accent">Birlikte</span><br>
            Keşfedelim
            <span class="intro-title-underline" aria-hidden="true">
              <svg viewBox="0 0 140 8" width="140" height="8" fill="none">
                <path d="M2 4 C35 0, 70 8, 105 4 C122 2, 132 6, 138 3" stroke="url(#titleLineGrad)" stroke-width="2" stroke-linecap="round"/>
                <defs>
                  <linearGradient id="titleLineGrad" x1="0" y1="0" x2="140" y2="0"><stop offset="0%" stop-color="#D96C5F"/><stop offset="50%" stop-color="#D98A5F"/><stop offset="100%" stop-color="#C99A4A"/></linearGradient>
                </defs>
              </svg>
            </span>
          </h2>

          <p class="intro-desc reveal-up">
            Her beden, her yaşam düzeni ve her hedef farklıdır. Bu yüzden hazır listeler yerine;
            günlük rutininize, sağlık hedeflerinize ve sürdürülebilir alışkanlıklara uygun bir
            beslenme modeli oluşturuyoruz.
          </p>

          <div class="intro-chips reveal-up">
            <div class="intro-chip">
              <div class="intro-chip-icon">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="none"><path d="M10 3C8 3 6 5 6 8C6 11 8 14 10 14C12 14 14 11 14 8C14 5 12 3 10 3Z" fill="var(--color-coral)"/><path d="M10 3C9 2 8 2 7 3C6 4 7 5 8 5C9 5 10 4 10 3Z" fill="var(--color-coral-dark)"/><path d="M10 3C11 2 12 2 13 3C14 4 13 5 12 5C11 5 10 4 10 3Z" fill="var(--color-coral-dark)"/></svg>
              </div>
              <span>Kişiye özel beslenme planı</span>
            </div>
            <div class="intro-chip">
              <div class="intro-chip-icon">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="none"><rect x="4" y="4" width="12" height="13" rx="2" fill="var(--color-sky)"/><rect x="6" y="6" width="8" height="1.5" rx="0.5" fill="var(--white)"/><rect x="6" y="9" width="6" height="1.5" rx="0.5" fill="var(--white)"/><rect x="6" y="12" width="5" height="1.5" rx="0.5" fill="var(--white)"/></svg>
              </div>
              <span>Online ve yüz yüze danışmanlık</span>
            </div>
            <div class="intro-chip">
              <div class="intro-chip-icon">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="none"><circle cx="10" cy="10" r="7" fill="var(--color-amber)"/><path d="M10 6V10L13 12" stroke="var(--white)" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <span>Sürdürülebilir alışkanlık takibi</span>
            </div>
            <div class="intro-chip">
              <div class="intro-chip-icon">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="none"><path d="M10 18C14 18 17 14 17 10C17 6 14 3 10 3C6 3 3 6 3 10C3 14 6 18 10 18Z" fill="var(--color-sage)"/><path d="M7 10H13" stroke="var(--white)" stroke-width="1.5" stroke-linecap="round"/><path d="M10 7V13" stroke="var(--white)" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <span>Kilo yönetimi ve metabolizma desteği</span>
            </div>
          </div>

          <div class="intro-actions reveal-up">
            <a href="/iletisim" class="btn btn-primary intro-btn-primary">Birlikte Başlayalım</a>
            <a href="/hizmetler" class="btn btn-outline intro-btn-outline">Programları İncele</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION DIVIDER 1 -->
  <div class="section-divider">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
      <path d="M0,60 C360,120 720,0 1080,60 C1260,90 1350,60 1440,60 L1440,0 L0,0 Z" fill="#FBF5EA"></path>
    </svg>
  </div>

  <!-- ABOUT SECTION -->
  <section class="about section" id="about">
    <div class="about-bg-shapes">
      <div class="about-shape as-1"></div>
      <div class="about-shape as-2"></div>
      <div class="about-shape as-3"></div>
      <div class="about-shape as-4"></div>
    </div>
    <div class="container">
      <div class="about-wrapper-new">
        
        <!-- Left: Premium Editorial Visual Column -->
        <div class="about-visual-showcase reveal-left">
          <div class="about-image-backdrop"></div>
          <div class="about-ambient-glow"></div>
          
          <div class="about-image-frame-new">
            <div class="about-image-card-new">
              <img src="<%= about.image + '?v=' + Date.now() %>" alt="Dyt. Fulya Sarı - Diyetisyen" class="about-profile-img-new" loading="lazy">
              <div class="about-img-overlay-new"></div>
            </div>
            
            <!-- Structural Line Ornaments representing precision and science -->
            <div class="about-decorative-frame-1"></div>
            <div class="about-decorative-frame-2"></div>
            <div class="about-decorative-line-v"></div>
            <div class="about-decorative-line-h"></div>
            
            <!-- Rotating Gold Experience Seal -->
            <div class="about-experience-seal">
              <div class="seal-inner">
                <div class="seal-badge">
                  <svg viewBox="0 0 100 100" class="seal-text-svg">
                    <path id="sealCurve" d="M 50,50 m -37,0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="none" />
                    <text class="seal-text">
                      <textPath href="#sealCurve" startOffset="50%" text-anchor="middle">
                        SAĞLIKLI YAŞAM • BESLENME • DANIŞMANLIK
                      </textPath>
                    </text>
                  </svg>
                  <div class="seal-center">
                    <span class="seal-number">2016</span>
                    <span class="seal-year">DEN BERİ</span>
                  </div>
                </div>
              </div>
            </div>
            
          </div>
        </div>
        
        <!-- Right: Editorial Narrative Column -->
        <div class="about-editorial-content reveal-right">
          <div class="about-brand-header">
            <span class="about-pre-title">Kişisel Marka &amp; Uzmanlık</span>
            <div class="about-title-group">
              <h2 class="about-editorial-title"><%= about.title %></h2>
              <span class="about-title-badge">Kurucu Diyetisyen</span>
            </div>
            <p class="about-editorial-subtitle"><%= about.subtitle %></p>
            <div class="about-title-underline-new"></div>
          </div>
          
          <div class="about-description-group">
            <% about.description.forEach((paragraph, idx) => { %>
              <p class="about-editorial-text <%= idx === 0 ? 'about-lead-paragraph' : '' %>">
                <%= paragraph %>
              </p>
            <% }); %>
          </div>

          <div class="about-pills-section">
            <span class="about-pills-title">Öne Çıkan Çalışma Alanları</span>
            <div class="about-expertise-new">
              <% about.expertise.forEach((item, index) => { %>
                <span class="expertise-pill-new pill-theme-<%= index % 4 %>">
                  <span class="pill-dot"></span>
                  <%= item %>
                </span>
              <% }); %>
            </div>
          </div>
          
          <div class="about-editorial-actions">
            <a href="/hakkimizda" class="about-luxury-cta">
              <span class="cta-text">Detaylı Özgeçmiş &amp; Vizyon</span>
              <span class="cta-arrow">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
            </a>
          </div>
        </div>
        
      </div>

      <!-- Bottom: Asymmetric Horizontal Premium Stat Strip -->
      <div class="about-stats-strip reveal-up">
        <div class="stats-strip-bg"></div>
        <div class="stats-strip-grid">
              <% about.stats.forEach((stat, index) => { %>
            <div class="stat-strip-item counter-item theme-color-<%= index % 4 %>">
              <div class="stat-strip-glow"></div>
              <div class="stat-strip-icon-wrap">
                <% if (index === 0) { %><i data-lucide="user-check" style="width:22px;height:22px;"></i><% } %>
                <% if (index === 1) { %><i data-lucide="monitor" style="width:22px;height:22px;"></i><% } %>
                <% if (index === 2) { %><i data-lucide="refresh-cw" style="width:22px;height:22px;"></i><% } %>
                <% if (index === 3) { %><i data-lucide="leaf" style="width:22px;height:22px;"></i><% } %>
              </div>
              <div class="stat-strip-text">
                <span class="stat-strip-number" data-target="<%= stat.number.replace(/[^0-9]/g, '') %>"><%= stat.number %></span>
                <span class="stat-strip-label"><%= stat.label %></span>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

    </div>
  </section>

  <!-- TRUST BADGES STRIP -->
  <div class="trust-strip">
    <div class="trust-strip-bg"></div>
    <div class="container">
      <div class="trust-strip-inner">
        <div class="trust-label-wrap">
          <div class="trust-label-icon"><i data-lucide="shield-check" style="width:16px;height:16px;"></i></div>
          <span class="trust-label">Güven Veren<br>Beslenme Danışmanlığı</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-track-wrapper">
          <div class="trust-track" id="trustTrack">
            <% 
              const badges = trustBadges.concat(trustBadges);
              badges.forEach(badge => { 
            %>
            <div class="trust-badge">
              <span class="trust-badge-icon"><i data-lucide="<%= badge.icon %>" style="width:14px;height:14px;"></i></span>
              <span class="trust-badge-label"><%= badge.label %></span>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <section class="process section" id="process">
    <div class="process-bg-shapes">
      <div class="pbs-1"></div><div class="pbs-2"></div>
    </div>
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">Çalışma Sürecimiz</span>
        <h2 class="section-title">Sağlıklı Yaşama Giden <span style="color:var(--accent)">Yol Haritanız</span></h2>
        <p class="section-subtitle">Bilimsel temelli, size özel planlanan 4 adımlı beslenme süreciyle hedeflerinize emin adımlarla ulaşın.</p>
      </div>
      <div class="process-track">
        <div class="process-line"><div class="process-line-fill"></div></div>
        <% process.forEach((step, i) => { %>
        <div class="process-step reveal-up">
          <div class="process-card">
            <div class="process-card-thumb">
              <img src="<%= step.image %>" alt="<%= step.title %>" loading="lazy" onerror="this.classList.add('img-error')">
              <div class="process-img-fallback" aria-hidden="true"><i data-lucide="<%= step.icon %>" style="width:32px;height:32px;"></i></div>
            </div>
            <div class="process-card-body">
              <div class="process-num"><%= String(i + 1).padStart(2, '0') %></div>
              <div class="process-icon"><i data-lucide="<%= step.icon %>" style="width:24px;height:24px;"></i></div>
              <h3><%= step.title %></h3>
              <p><%= step.desc %></p>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- SECTION DIVIDER 2 -->
  <div class="section-divider flip">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
      <path d="M0,60 C360,120 720,0 1080,60 C1260,90 1350,60 1440,60 L1440,0 L0,0 Z" fill="#F2E8D8"></path>
    </svg>
  </div>

  <!-- SERVICES SECTION -->
  <section class="services section" id="services">
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">Hizmetlerimiz</span>
        <h2 class="section-title">Uzmanlık Alanlarımızla <span style="color:var(--accent)">Yanınızdayız</span></h2>
        <p class="section-subtitle">Nöroendokrin beslenmeden duygusal yeme danışmanlığına, hormonal denge programlarından online koçluğa kadar bilimsel temelli çözümler sunuyoruz.</p>
      </div>
      <div class="services-grid">
        <% services.forEach((service, idx) => { %>
        <div class="service-card reveal-up<%= idx === 0 ? ' service-card-featured' : '' %>">
          <div class="service-card-img">
            <img src="<%= service.image %>" alt="<%= service.title %>" loading="lazy" onerror="this.classList.add('img-error')">
            <div class="service-img-fallback" aria-hidden="true"><i data-lucide="<%= service.icon %>" style="width:36px;height:36px;"></i></div>
          </div>
          <div class="service-card-body">
            <div class="service-icon"><i data-lucide="<%= service.icon %>" style="width:<%= idx === 0 ? 32 : 26 %>px;height:<%= idx === 0 ? 32 : 26 %>px;"></i></div>
            <h3 class="service-title"><%= service.title %></h3>
            <p class="service-desc"><%= service.description %></p>
            <a href="/iletisim" class="service-link">Programı Keşfet <i data-lucide="arrow-right" style="width:14px;height:14px;"></i></a>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner" id="ctaBanner">
    <div class="cta-particles"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="reveal-up">Kendinize Yapacağınız <span style="color:var(--accent)">En Değerli Yatırım</span></h2>
        <p class="reveal-up">Ücretsiz ön görüşme ile size özel beslenme programını keşfedin. Sağlıklı bir yaşam bir randevu kadar yakın.</p>
        <a href="/iletisim" class="btn btn-primary btn-lg reveal-up"><span>Randevu Al</span></a>
      </div>
    </div>
  </section>

  <!-- VALUE / HIGHLIGHT SECTION — Premium Editorial Information Block -->
  <section class="value-section" id="valueSection">
    <div class="value-shapes">
      <div class="value-shape vs-1"></div>
      <div class="value-shape vs-2"></div>
      <div class="value-shape vs-3"></div>
    </div>
    <div class="container">
      <div class="value-header reveal-up">
        <span class="value-badge">Neden Birlikte Çalışmalısınız?</span>
        <h2 class="value-title">Diyetinizle Hayatınıza <span class="value-title-accent">Renk Katın</span></h2>
        <p class="value-desc">Her danışanımıza özel, bilimsel temelli ve sürdürülebilir beslenme çözümleri sunuyoruz. Amacımız sadece kilo verdirmek değil, sağlıklı bir yaşam kültürü kazandırmak.</p>
      </div>
      <div class="value-grid">
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-coral">
            <i data-lucide="users" style="width:24px;height:24px;"></i>
          </div>
          <h4>Yüz Yüze Beslenme Danışmanlığı</h4>
          <p>Antalya merkez ofisimizde birebir görüşmelerle size özel program oluşturuyor, ilerlemenizi yakından takip ediyoruz.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-sky">
            <i data-lucide="laptop" style="width:24px;height:24px;"></i>
          </div>
          <h4>Online Beslenme Koçluğu</h4>
          <p>Dilediğiniz yerden görüntülü görüşme ile danışmanlık alın. Haftalık takip, öğün planlaması ve anlık destek dahil.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-amber">
            <i data-lucide="apple" style="width:24px;height:24px;"></i>
          </div>
          <h4>Sağlıklı Beslenme Programı</h4>
          <p>Yaşam tarzınıza, kan değerlerinize ve hedeflerinize göre hazırlanan bilimsel temelli beslenme planları.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-sage">
            <i data-lucide="dumbbell" style="width:24px;height:24px;"></i>
          </div>
          <h4>Sporcu Beslenme Danışmanlığı</h4>
          <p>Performans hedeflerinize uygun makro ve mikro besin planlaması ile antrenman veriminizi maksimuma çıkarın.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-coral">
            <i data-lucide="building" style="width:24px;height:24px;"></i>
          </div>
          <h4>Kurumsal Beslenme Danışmanlığı</h4>
          <p>Şirketinize özel beslenme seminerleri, toplu sağlık taramaları ve çalışan motivasyon programları düzenliyoruz.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-sky">
            <i data-lucide="leaf" style="width:24px;height:24px;"></i>
          </div>
          <h4>Vejetaryen &amp; Vegan Beslenme</h4>
          <p>Bitkisel bazlı beslenen danışanlarımız için eksiksiz, dengeli ve sürdürülebilir öğün planları hazırlıyoruz.</p>
        </div>
      </div>
      <div class="value-actions reveal-up">
        <a href="/iletisim" class="btn btn-primary btn-lg"><span>Birlikte Çalışalım</span></a>
        <a href="/hizmetler" class="btn btn-outline btn-lg">Tüm Hizmetleri Keşfedin <i data-lucide="arrow-right" style="width:16px;height:16px;"></i></a>
      </div>
    </div>
  </section>

  <!-- BLOG SECTION -->
  <section class="blog section bg-light" id="blog">
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">Blog</span>
        <h2 class="section-title">Beslenme Biliminden <span style="color:var(--accent)">Güncel Yazılar</span></h2>
        <p class="section-subtitle">Diyetisyen Fulya Sarı kaleminden sağlıklı beslenme, kilo yönetimi, hormonal denge ve yaşam tarzı üzerine uzman görüşleri.</p>
      </div>
      <div class="blog-grid">
        <% recentMakaleler.forEach(function(makale) { %>
        <article class="blog-card reveal-up">
          <div class="blog-card-image">
            <% if (makale.image && makale.image.startsWith('http')) { %>
            <img src="<%= makale.image %>" alt="<%= makale.title %>" loading="lazy" />
            <% } else { %>
            <div class="blog-img-placeholder">
              <i data-lucide="leaf" style="width:30px;height:30px;"></i>
            </div>
            <% } %>
            <span class="blog-category"><%= makale.category %></span>
          </div>
          <div class="blog-card-body">
            <div class="blog-meta">
              <span><i data-lucide="calendar" style="width:14px;height:14px;"></i> <%= makale.date %></span>
              <span><i data-lucide="clock" style="width:14px;height:14px;"></i> <%= makale.readTime %> dk okuma</span>
            </div>
            <h3 class="blog-card-title">
              <a href="/makale/<%= makale.slug %>"><%= makale.title %></a>
            </h3>
            <p class="blog-card-desc"><%= makale.metaDesc.substring(0, 120) %>...</p>
            <a href="/makale/<%= makale.slug %>" class="blog-read-more">Yazıyı Oku <i data-lucide="arrow-right" style="width:14px;height:14px;"></i></a>
          </div>
        </article>
        <% }); %>
      </div>
      <div class="blog-more">
        <a href="/makaleler" class="btn btn-primary"><span>Tüm Yazıları Gör</span></a>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section class="faq section" id="faq">
    <div class="container">
      <div class="faq-wrapper">
        <div class="faq-left reveal-left">
          <span class="section-tag">SSS</span>
          <h2 class="section-title gradient-text">Sık Sorulan Sorular</h2>
          <p class="section-subtitle">Diyet, beslenme ve danışmanlık süreci hakkında en çok merak edilenleri uzmanımız yanıtlıyor.</p>
          <div class="faq-cta">
            <p>Sormak istediğiniz başka bir şey var mı? Size özel beslenme planı için ücretsiz ön görüşme randevusu alabilirsiniz.</p>
            <a href="/iletisim" class="btn btn-primary"><span>Hemen Sorun</span></a>
          </div>
        </div>
        <div class="faq-right reveal-right">
          <% faq.forEach((item, i) => { %>
          <div class="faq-item <%= i === 0 ? 'active' : '' %>">
            <div class="faq-question">
              <span><%= item.question %></span>
              <i data-lucide="chevron-down" style="width:16px;height:16px;"></i>
            </div>
            <div class="faq-answer">
              <p><%= item.answer %></p>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="contact section" id="contact">
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">İletişim</span>
        <h2 class="section-title">Randevu ve <span style="color:var(--accent)">Bilgi İçin</span></h2>
        <p class="section-subtitle">Size özel beslenme programına başlamak için bizimle iletişime geçin. İlk adımı atmak çok kolay.</p>
      </div>
      <div class="contact-wrapper">
        <div class="contact-info">
          <div class="contact-card glass-card reveal-left">
            <div class="contact-card-bg"></div>
            <i data-lucide="map-pin" style="width:28px;height:28px;"></i>
            <h4>Adres</h4>
            <p><%= site.address %></p>
          </div>
          <div class="contact-card glass-card reveal-left">
            <div class="contact-card-bg"></div>
            <i data-lucide="phone" style="width:28px;height:28px;"></i>
            <h4>Telefon</h4>
            <p><%= site.phone %></p>
          </div>
          <div class="contact-card glass-card reveal-left">
            <div class="contact-card-bg"></div>
            <i data-lucide="mail" style="width:28px;height:28px;"></i>
            <h4>E-posta</h4>
            <p><%= site.email %></p>
          </div>
          <div class="contact-card glass-card reveal-left">
            <div class="contact-card-bg"></div>
            <i data-lucide="clock" style="width:28px;height:28px;"></i>
            <h4>Çalışma Saatleri</h4>
            <p><%= site.workingHours %></p>
          </div>
        </div>
        <form class="contact-form reveal-right" action="/iletisim" method="POST" novalidate>
          <div class="form-shine"></div>
          <div class="form-row">
            <div class="form-group">
              <label for="index-name" class="form-label">Adınız Soyadınız <span class="required">*</span></label>
              <input type="text" id="index-name" name="name" placeholder="Adınız Soyadınız" required minlength="2" autocomplete="name">
              <span class="form-error">Lütfen adınızı girin</span>
            </div>
            <div class="form-group">
              <label for="index-email" class="form-label">E-posta Adresiniz <span class="required">*</span></label>
              <input type="email" id="index-email" name="email" placeholder="ornek@mail.com" required autocomplete="email">
              <span class="form-error">Geçerli bir e-posta girin</span>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="index-phone" class="form-label">Telefon</label>
              <input type="tel" id="index-phone" name="phone" placeholder="0532 123 45 67" autocomplete="tel">
            </div>
            <div class="form-group">
              <label for="index-service" class="form-label">Hizmet</label>
              <select id="index-service" name="service">
                <option value="">Hizmet Seçiniz</option>
                <option>Kişisel Diyet Programı</option>
                <option>Hastalık Diyeti</option>
                <option>Gebelik Beslenmesi</option>
                <option>Sporcu Beslenmesi</option>
                <option>Detoks Programı</option>
                <option>Diğer</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="index-message" class="form-label">Mesajınız</label>
            <textarea id="index-message" name="message" rows="5" placeholder="Mesajınızı yazın..." maxlength="2000"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-block"><span>Gönder</span></button>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
