<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="scroll-progress" id="scrollProgress"></div>

<% if (success) { %>
<div class="toast toast-success" id="formSuccess">
  <i data-lucide="check-circle" style="width:20px;height:20px;"></i>
  <span>Mesajınız başarıyla gönderildi! En kısa sürede size dönüş yapacağız.</span>
  <button class="toast-close" onclick="this.parentElement.remove()">&times;</button>
</div>
<% } %>

<main>
  <!-- HERO — Konsept A: Light Premium Wellness -->
  <section class="hero" id="hero">

    <!-- Layered background -->
    <div class="hero-bg-layer">
      <div class="hero-bg-blob hero-bg-blob-1"></div>
      <div class="hero-bg-blob hero-bg-blob-2"></div>
      <div class="hero-bg-blob hero-bg-blob-3"></div>
    </div>

    <!-- Parallax soft shapes -->
    <div class="hero-parallax-shapes" aria-hidden="true">
      <div class="parallax-shape ps-1" data-speed="0.02"></div>
      <div class="parallax-shape ps-2" data-speed="0.03"></div>
      <div class="parallax-shape ps-3" data-speed="0.015"></div>
    </div>

    <!-- Noise grain -->
    <div class="hero-grain" aria-hidden="true"></div>

    <!-- Nutrition pattern dots -->
    <div class="hero-nutrition-pattern" aria-hidden="true"></div>

    <!-- Soft overlay -->
    <div class="hero-overlay"></div>

    <div class="container">
      <div class="hero-wrapper">

        <!-- Left Content -->
        <div class="hero-left">
          <span class="hero-badge hero-anim hero-anim-delay-1">
            <span class="hero-badge-dot"></span>
            ANTALYA &amp; ONLINE BESLENME DANIŞMANLIĞI
          </span>

          <h1 class="hero-title hero-anim hero-anim-delay-2">
            <span class="line" style="--line-i:0"><span>Dyt. Fulya Sarı ile</span></span>
            <span class="line" style="--line-i:1"><span>Kişiye Özel Beslenme</span></span>
            <span class="line" style="--line-i:2"><span>Danışmanlığı</span></span>
          </h1>

          <div class="hero-rotator hero-anim hero-anim-delay-3">
            <span class="hero-rotator-prefix">Uzmanlık:</span>
            <div class="hero-rotator-words" id="wordRotator">
              <span class="rotator-word active">Kilo Yönetimi</span>
              <span class="rotator-word">Online Koçluk</span>
              <span class="rotator-word">Yüz Yüze Görüşme</span>
              <span class="rotator-word">Sürdürülebilirlik</span>
              <span class="rotator-word">Öğün Planlaması</span>
              <span class="rotator-word">Takip ve Motivasyon</span>
            </div>
          </div>

          <p class="hero-desc hero-anim hero-anim-delay-4">
            Yaşam tarzınıza, hedeflerinize ve ihtiyaçlarınıza uygun; sürdürülebilir, kişiye özel beslenme programlarıyla sağlıklı yaşam yolculuğunuzda yanınızdayız.
          </p>

          <div class="hero-actions hero-anim hero-anim-delay-5">
            <a href="/iletisim" class="btn-hero-primary">Randevu Al</a>
            <a href="/hizmetler" class="btn-hero-outline">Programları İncele</a>
          </div>

          <div class="hero-pills hero-anim hero-anim-delay-6">
            <div class="hero-pill">
              <span class="hero-pill-icon"><i data-lucide="laptop" style="width:14px;height:14px;"></i></span>
              <span>Online &amp; Yüz Yüze</span>
            </div>
            <div class="hero-pill">
              <span class="hero-pill-icon"><i data-lucide="user-check" style="width:14px;height:14px;"></i></span>
              <span>Kişiye Özel Program</span>
            </div>
            <div class="hero-pill">
              <span class="hero-pill-icon"><i data-lucide="refresh-cw" style="width:14px;height:14px;"></i></span>
              <span>Takip &amp; Destek</span>
            </div>
          </div>
        </div>

        <!-- Right: Portrait + Floating Cards -->
        <div class="hero-right">
          <div class="hero-portrait">

            <!-- Abstract orbit rings behind portrait -->
            <div class="hero-orbit-ring orbit-1" aria-hidden="true"></div>
            <div class="hero-orbit-ring orbit-2" aria-hidden="true"></div>

            <!-- Status ring around portrait -->
            <div class="hero-status-ring" aria-hidden="true"></div>

            <!-- Floating glass cards around portrait -->
            <div class="hero-floating-cards">
              <div class="floating-card fc-1">
                <i data-lucide="leaf" style="width:14px;height:14px;"></i>
                <span>Sürdürülebilir Sağlık</span>
              </div>
              <div class="floating-card fc-2">
                <i data-lucide="heart" style="width:14px;height:14px;"></i>
                <span>Birebir Koçluk</span>
              </div>
              <div class="floating-card fc-3">
                <i data-lucide="shield" style="width:14px;height:14px;"></i>
                <span>Yaşam Boyu Destek</span>
              </div>
              <div class="floating-card fc-4">
                <i data-lucide="star" style="width:14px;height:14px;"></i>
                <span>Güvenilir Danışmanlık</span>
              </div>
            </div>

            <div class="hero-portrait-card">
              <img src="/images/hakkimizda.jpeg?v=2" alt="Dyt. Fulya Sarı" class="hero-portrait-img" loading="eager">
              <div class="hero-portrait-frame"></div>
              <div class="hero-portrait-glow"></div>
            </div>
            <div class="hero-portrait-badge">
              <span class="badge-number">2016</span>
              <span class="badge-text">DAN BERİ</span>
            </div>
            <div class="hero-portrait-info pi-1">
              <i data-lucide="map-pin" style="width:14px;height:14px;"></i>
              <span>Antalya</span>
            </div>
            <div class="hero-portrait-info pi-2">
              <i data-lucide="globe" style="width:14px;height:14px;"></i>
              <span>Online</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Marquee expertise strip -->
    <div class="hero-marquee">
      <div class="hero-marquee-track" id="marqueeTrack">
        <span class="hero-marquee-item">Bilimsel Yaklaşım</span>
        <span class="hero-marquee-item">Hormonal Denge</span>
        <span class="hero-marquee-item">Bağırsak Sağlığı</span>
        <span class="hero-marquee-item">Duygusal Yeme</span>
        <span class="hero-marquee-item">Sporcu Beslenmesi</span>
        <span class="hero-marquee-item">Glisemik Kontrol</span>
        <span class="hero-marquee-item">Vücut Analizi</span>
        <span class="hero-marquee-item">Anti-enflamatuar</span>
        <span class="hero-marquee-item">Metabolizma Desteği</span>
        <span class="hero-marquee-item">Vitamin Dengesi</span>
        <span class="hero-marquee-item">Nöroendokrin Beslenme</span>
        <span class="hero-marquee-item">Uyku &amp; Hormon</span>
        <span class="hero-marquee-item">Sağlıklı Alışkanlıklar</span>
        <span class="hero-marquee-item">Fonksiyonel Tıp</span>
        <span class="hero-marquee-item hero-marquee-channel">
          <i data-lucide="youtube" style="width:14px;height:14px;"></i>
          <span>@dytfulyasari</span>
        </span>
        <span class="hero-marquee-item">Bilimsel Yaklaşım</span>
        <span class="hero-marquee-item">Hormonal Denge</span>
        <span class="hero-marquee-item">Bağırsak Sağlığı</span>
        <span class="hero-marquee-item">Duygusal Yeme</span>
        <span class="hero-marquee-item">Sporcu Beslenmesi</span>
        <span class="hero-marquee-item">Glisemik Kontrol</span>
        <span class="hero-marquee-item">Vücut Analizi</span>
        <span class="hero-marquee-item">Anti-enflamatuar</span>
        <span class="hero-marquee-item">Metabolizma Desteği</span>
        <span class="hero-marquee-item">Vitamin Dengesi</span>
        <span class="hero-marquee-item">Nöroendokrin Beslenme</span>
        <span class="hero-marquee-item">Uyku &amp; Hormon</span>
        <span class="hero-marquee-item">Sağlıklı Alışkanlıklar</span>
        <span class="hero-marquee-item">Fonksiyonel Tıp</span>
        <span class="hero-marquee-item hero-marquee-channel">
          <i data-lucide="youtube" style="width:14px;height:14px;"></i>
          <span>@dytfulyasari</span>
        </span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <a href="#processSection" class="hero-scroll-indicator" aria-label="Sonraki bölüme kaydır">
      <span>Aşağı Kaydır</span>
      <div class="scroll-mouse"><div class="scroll-dot"></div></div>
    </a>
  </section>

  <!-- YOUTUBE CHANNEL INTRO -->
  <section class="channel-intro">
    <div class="container">
      <div class="channel-intro-card">
        <div class="channel-intro-bg"></div>
        <div class="channel-intro-content">
          <div class="channel-intro-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </div>
          <div class="channel-intro-text">
            <h3 class="channel-intro-title">Dyt. Fulya Sarı YouTube Kanalı</h3>
            <p class="channel-intro-quote">"Sadece ne yediğini değil, neden yediğini de anlayacağın bir kanal."</p>
            <p class="channel-intro-desc">Bilim var, sinyaller var, hormonlar var. Karışık değil, sade. Nöroendokrinoloji, davranışsal beslenme ve sürdürülebilir dönüşüm üzerine.</p>
          </div>
          <a href="https://www.youtube.com/@dytfulyasari" target="_blank" rel="noopener" class="channel-intro-btn">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <span>Kanala Git</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DANIŞMANLIK SÜRECİMİZ -->
  <section class="process-intro" id="processSection">
    <div class="container">
      <div class="process-intro-header">
        <span class="process-intro-badge">NASIL ÇALIŞIYORUZ</span>
        <h2 class="process-intro-title">Danışmanlık Sürecimiz</h2>
        <p class="process-intro-desc">
          Hedeflerinize ulaşmanız için adım adım yanınızdayız. Bilimsel temelli, kişiye özel bir yol haritası ile sürdürülebilir başarıya birlikte yürüyoruz.
        </p>
      </div>
      <div class="process-intro-video">
        <iframe src="https://www.youtube.com/embed/em79KDkdogc?autoplay=0&rel=0" title="Nasıl Çalışıyoruz" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
      </div>
      <div class="process-intro-grid">
        <% process.forEach((step, i) => { %>
        <div class="process-intro-card">
          <div class="pic-step"><%= String(i + 1).padStart(2, '0') %></div>
          <div class="pic-icon"><i data-lucide="<%= step.icon %>" style="width:26px;height:26px;"></i></div>
          <h3 class="pic-title"><%= step.title %></h3>
          <p class="pic-desc"><%= step.desc %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- SECTION DIVIDER 1 -->
  <div class="section-divider">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
      <path d="M0,60 C360,120 720,0 1080,60 C1260,90 1350,60 1440,60 L1440,0 L0,0 Z" fill="#FBF5EA"></path>
    </svg>
  </div>

  <!-- ABOUT SECTION -->
  <section class="about section" id="about">
    <div class="about-bg-shapes">
      <div class="about-shape as-1"></div>
      <div class="about-shape as-2"></div>
      <div class="about-shape as-3"></div>
      <div class="about-shape as-4"></div>
    </div>
    <div class="container">
      <div class="about-wrapper-new">
        
        <!-- Left: Premium Editorial Visual Column -->
        <div class="about-visual-showcase reveal-left">
          <div class="about-image-backdrop"></div>
          <div class="about-ambient-glow"></div>
          
          <div class="about-image-frame-new">
            <div class="about-image-card-new about-image-scale">
              <img src="<%= about.image + '?v=2' %>" alt="Dyt. Fulya Sarı - Diyetisyen" class="about-profile-img-new" loading="lazy">
              <div class="about-img-overlay-new"></div>
            </div>
            
            <!-- Structural Line Ornaments representing precision and science -->
            <div class="about-decorative-frame-1"></div>
            <div class="about-decorative-frame-2"></div>
            <div class="about-decorative-line-v"></div>
            <div class="about-decorative-line-h"></div>
            
            <!-- Rotating Gold Experience Seal -->
            <div class="about-experience-seal">
              <div class="seal-inner">
                <div class="seal-badge">
                  <svg viewBox="0 0 100 100" class="seal-text-svg">
                    <path id="sealCurve" d="M 50,50 m -37,0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="none" />
                    <text class="seal-text">
                      <textPath href="#sealCurve" startOffset="50%" text-anchor="middle">
                        SAĞLIKLI YAŞAM • BESLENME • DANIŞMANLIK
                      </textPath>
                    </text>
                  </svg>
                  <div class="seal-center">
                    <span class="seal-number">2016</span>
                    <span class="seal-year">DEN BERİ</span>
                  </div>
                </div>
              </div>
            </div>
            
          </div>
        </div>
        
        <!-- Right: Editorial Narrative Column -->
        <div class="about-editorial-content reveal-right">
          <div class="about-brand-header">
            <span class="about-pre-title">Kişisel Marka &amp; Uzmanlık</span>
            <div class="about-title-group">
              <h2 class="about-editorial-title"><%= about.title %></h2>
              <span class="about-title-badge">Kurucu Diyetisyen</span>
            </div>
            <p class="about-editorial-subtitle"><%= about.subtitle %></p>
            <div class="about-title-underline-new"></div>
          </div>
          
          <div class="about-description-group reveal-stagger">
            <% about.description.forEach((paragraph, idx) => { %>
              <p class="about-editorial-text <%= idx === 0 ? 'about-lead-paragraph' : '' %>">
                <%= paragraph %>
              </p>
            <% }); %>
          </div>

          <div class="about-pills-section">
            <span class="about-pills-title">Öne Çıkan Çalışma Alanları</span>
            <div class="about-expertise-new reveal-stagger">
              <% about.expertise.forEach((item, index) => { %>
                <span class="expertise-pill-new pill-theme-<%= index % 4 %>">
                  <span class="pill-dot"></span>
                  <%= item %>
                </span>
              <% }); %>
            </div>
          </div>
          
          <div class="about-editorial-actions">
            <a href="/hakkimizda" class="about-luxury-cta">
              <span class="cta-text">Detaylı Özgeçmiş &amp; Vizyon</span>
              <span class="cta-arrow">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
            </a>
          </div>
        </div>
        
      </div>

      <!-- Bottom: Asymmetric Horizontal Premium Stat Strip -->
      <div class="about-stats-strip reveal-up">
        <div class="stats-strip-bg"></div>
        <div class="stats-strip-grid">
              <% about.stats.forEach((stat, index) => { %>
            <div class="stat-strip-item counter-item theme-color-<%= index % 4 %>">
              <div class="stat-strip-glow"></div>
              <div class="stat-strip-icon-wrap">
                <% if (index === 0) { %><i data-lucide="user-check" style="width:22px;height:22px;"></i><% } %>
                <% if (index === 1) { %><i data-lucide="monitor" style="width:22px;height:22px;"></i><% } %>
                <% if (index === 2) { %><i data-lucide="refresh-cw" style="width:22px;height:22px;"></i><% } %>
                <% if (index === 3) { %><i data-lucide="leaf" style="width:22px;height:22px;"></i><% } %>
              </div>
              <div class="stat-strip-text">
                <span class="stat-strip-number" data-target="<%= stat.number.replace(/[^0-9]/g, '') %>"><%= stat.number %></span>
                <span class="stat-strip-label"><%= stat.label %></span>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

    </div>
  </section>

  <!-- YOUTUBE SHORTS -->
  <section class="youtube-shorts section" id="youtubeShorts">
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">KISA VİDEOLAR</span>
        <h2 class="section-title">Sağlıklı Yaşam <span style="color:var(--accent)">İpuçları</span></h2>
        <p class="section-subtitle">Dyt. Fulya Sarı'nın YouTube Shorts videolarıyla beslenme, kilo yönetimi ve sağlıklı yaşam hakkında pratik bilgiler.</p>
      </div>
      <div class="shorts-grid">
        <div class="shorts-card reveal-up">
          <div class="shorts-thumb">
            <iframe src="https://www.youtube.com/embed/YCUsaUcsY48?autoplay=0&rel=0" title="9 Haziran 2026" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <div class="shorts-body">
            <h3 class="shorts-title">9 Haziran 2026</h3>
          </div>
        </div>
        <div class="shorts-card reveal-up">
          <div class="shorts-thumb">
            <iframe src="https://www.youtube.com/embed/GK4D1ofaiX0?autoplay=0&rel=0" title="Stres Yönetimi" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <div class="shorts-body">
            <h3 class="shorts-title">Stres Yönetimi &amp; Kilo Verme</h3>
          </div>
        </div>
        <div class="shorts-card reveal-up">
          <div class="shorts-thumb">
            <iframe src="https://www.youtube.com/embed/SWZpjfuCQFU?autoplay=0&rel=0" title="Alt Karın Neden Olur?" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <div class="shorts-body">
            <h3 class="shorts-title">Alt Karın Neden Olur? Part 1</h3>
          </div>
        </div>
        <div class="shorts-card reveal-up">
          <div class="shorts-thumb">
            <iframe src="https://www.youtube.com/embed/GJaZXNktMmo?autoplay=0&rel=0" title="LDL Kolesterol" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <div class="shorts-body">
            <h3 class="shorts-title">LDL Kolesterol &amp; Kalp Sağlığı</h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES STRIP -->
  <div class="trust-strip">
    <div class="trust-strip-bg"></div>
    <div class="container">
      <div class="trust-strip-inner">
        <div class="trust-label-wrap">
          <div class="trust-label-icon"><i data-lucide="shield-check" style="width:16px;height:16px;"></i></div>
          <span class="trust-label">Güven Veren<br>Beslenme Danışmanlığı</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-track-wrapper">
          <div class="trust-track" id="trustTrack">
            <% 
              const badges = trustBadges.concat(trustBadges);
              badges.forEach(badge => { 
            %>
            <div class="trust-badge">
              <span class="trust-badge-icon"><i data-lucide="<%= badge.icon %>" style="width:14px;height:14px;"></i></span>
              <span class="trust-badge-label"><%= badge.label %></span>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <section class="process section" id="process">
    <div class="process-bg-shapes">
      <div class="pbs-1"></div><div class="pbs-2"></div>
    </div>
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">Çalışma Sürecimiz</span>
        <h2 class="section-title">Sağlıklı Yaşama Giden <span style="color:var(--accent)">Yol Haritanız</span></h2>
        <p class="section-subtitle">Bilimsel temelli, size özel planlanan 4 adımlı beslenme süreciyle hedeflerinize emin adımlarla ulaşın.</p>
      </div>
      <div class="process-track">
        <div class="process-line"><div class="process-line-fill"></div></div>
        <% process.forEach((step, i) => { %>
        <div class="process-step reveal-up">
          <div class="process-card">
            <div class="process-card-thumb">
              <img src="<%= step.image %>" alt="<%= step.title %>" loading="lazy" onerror="this.classList.add('img-error')">
              <div class="process-img-fallback" aria-hidden="true"><i data-lucide="<%= step.icon %>" style="width:32px;height:32px;"></i></div>
            </div>
            <div class="process-card-body">
              <div class="process-num"><%= String(i + 1).padStart(2, '0') %></div>
              <div class="process-icon"><i data-lucide="<%= step.icon %>" style="width:24px;height:24px;"></i></div>
              <h3><%= step.title %></h3>
              <p><%= step.desc %></p>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- SECTION DIVIDER 2 -->
  <div class="section-divider flip">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
      <path d="M0,60 C360,120 720,0 1080,60 C1260,90 1350,60 1440,60 L1440,0 L0,0 Z" fill="#F2E8D8"></path>
    </svg>
  </div>

  <!-- SERVICES SECTION -->
  <section class="services section" id="services">
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">Hizmetlerimiz</span>
        <h2 class="section-title">Uzmanlık Alanlarımızla <span style="color:var(--accent)">Yanınızdayız</span></h2>
        <p class="section-subtitle">Nöroendokrin beslenmeden duygusal yeme danışmanlığına, hormonal denge programlarından online koçluğa kadar bilimsel temelli çözümler sunuyoruz.</p>
      </div>
      <div class="services-grid">
        <% services.forEach((service, idx) => { %>
        <div class="service-card reveal-up<%= idx === 0 ? ' service-card-featured' : '' %>">
          <div class="service-card-img">
            <img src="<%= service.image %>" alt="<%= service.title %>" loading="lazy" onerror="this.classList.add('img-error')">
            <div class="service-img-fallback" aria-hidden="true"><i data-lucide="<%= service.icon %>" style="width:36px;height:36px;"></i></div>
          </div>
          <div class="service-card-body">
            <div class="service-icon"><i data-lucide="<%= service.icon %>" style="width:<%= idx === 0 ? 32 : 26 %>px;height:<%= idx === 0 ? 32 : 26 %>px;"></i></div>
            <h3 class="service-title"><%= service.title %></h3>
            <p class="service-desc"><%= service.description %></p>
            <a href="/iletisim" class="service-link">Programı Keşfet <i data-lucide="arrow-right" style="width:14px;height:14px;"></i></a>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner" id="ctaBanner">
    <div class="cta-particles"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="reveal-up">Kendinize Yapacağınız <span style="color:var(--accent)">En Değerli Yatırım</span></h2>
        <p class="reveal-up">Ücretsiz ön görüşme ile size özel beslenme programını keşfedin. Sağlıklı bir yaşam bir randevu kadar yakın.</p>
        <a href="/iletisim" class="btn btn-primary btn-lg reveal-up"><span>Randevu Al</span></a>
      </div>
    </div>
  </section>

  <!-- VALUE / HIGHLIGHT SECTION — Premium Editorial Information Block -->
  <section class="value-section" id="valueSection">
    <div class="value-shapes">
      <div class="value-shape vs-1"></div>
      <div class="value-shape vs-2"></div>
      <div class="value-shape vs-3"></div>
    </div>
    <div class="container">
      <div class="value-header reveal-up">
        <span class="value-badge">Neden Birlikte Çalışmalısınız?</span>
        <h2 class="value-title">Diyetinizle Hayatınıza <span class="value-title-accent">Renk Katın</span></h2>
        <p class="value-desc">Her danışanımıza özel, bilimsel temelli ve sürdürülebilir beslenme çözümleri sunuyoruz. Amacımız sadece kilo verdirmek değil, sağlıklı bir yaşam kültürü kazandırmak.</p>
      </div>
      <div class="value-grid">
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-coral">
            <i data-lucide="users" style="width:24px;height:24px;"></i>
          </div>
          <h4>Yüz Yüze Beslenme Danışmanlığı</h4>
          <p>Antalya merkez ofisimizde birebir görüşmelerle size özel program oluşturuyor, ilerlemenizi yakından takip ediyoruz.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-sky">
            <i data-lucide="laptop" style="width:24px;height:24px;"></i>
          </div>
          <h4>Online Beslenme Koçluğu</h4>
          <p>Dilediğiniz yerden görüntülü görüşme ile danışmanlık alın. Haftalık takip, öğün planlaması ve anlık destek dahil.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-amber">
            <i data-lucide="apple" style="width:24px;height:24px;"></i>
          </div>
          <h4>Sağlıklı Beslenme Programı</h4>
          <p>Yaşam tarzınıza, kan değerlerinize ve hedeflerinize göre hazırlanan bilimsel temelli beslenme planları.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-sage">
            <i data-lucide="dumbbell" style="width:24px;height:24px;"></i>
          </div>
          <h4>Sporcu Beslenme Danışmanlığı</h4>
          <p>Performans hedeflerinize uygun makro ve mikro besin planlaması ile antrenman veriminizi maksimuma çıkarın.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-coral">
            <i data-lucide="building" style="width:24px;height:24px;"></i>
          </div>
          <h4>Kurumsal Beslenme Danışmanlığı</h4>
          <p>Şirketinize özel beslenme seminerleri, toplu sağlık taramaları ve çalışan motivasyon programları düzenliyoruz.</p>
        </div>
        <div class="value-card reveal-up">
          <div class="value-card-icon vci-sky">
            <i data-lucide="leaf" style="width:24px;height:24px;"></i>
          </div>
          <h4>Vejetaryen &amp; Vegan Beslenme</h4>
          <p>Bitkisel bazlı beslenen danışanlarımız için eksiksiz, dengeli ve sürdürülebilir öğün planları hazırlıyoruz.</p>
        </div>
      </div>
      <div class="value-actions reveal-up">
        <a href="/iletisim" class="btn btn-primary btn-lg"><span>Birlikte Çalışalım</span></a>
        <a href="/hizmetler" class="btn btn-outline btn-lg">Tüm Hizmetleri Keşfedin <i data-lucide="arrow-right" style="width:16px;height:16px;"></i></a>
      </div>
    </div>
  </section>

  <!-- BLOG SECTION -->
  <section class="blog section bg-light" id="blog">
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">Blog</span>
        <h2 class="section-title">Beslenme Biliminden <span style="color:var(--accent)">Güncel Yazılar</span></h2>
        <p class="section-subtitle">Diyetisyen Fulya Sarı kaleminden sağlıklı beslenme, kilo yönetimi, hormonal denge ve yaşam tarzı üzerine uzman görüşleri.</p>
      </div>
      <div class="blog-grid">
        <% recentMakaleler.forEach(function(makale) { %>
        <article class="blog-card reveal-up">
          <div class="blog-card-image">
            <% if (makale.image && makale.image.startsWith('http')) { %>
            <img src="<%= makale.image %>" alt="<%= makale.title %>" loading="lazy" />
            <% } else { %>
            <div class="blog-img-placeholder">
              <i data-lucide="leaf" style="width:30px;height:30px;"></i>
            </div>
            <% } %>
            <span class="blog-category"><%= makale.category %></span>
          </div>
          <div class="blog-card-body">
            <div class="blog-meta">
              <span><i data-lucide="calendar" style="width:14px;height:14px;"></i> <%= makale.date %></span>
              <span><i data-lucide="clock" style="width:14px;height:14px;"></i> <%= makale.readTime %> dk okuma</span>
            </div>
            <h3 class="blog-card-title">
              <a href="/makale/<%= makale.slug %>"><%= makale.title %></a>
            </h3>
            <p class="blog-card-desc"><%= makale.metaDesc.substring(0, 120) %>...</p>
            <a href="/makale/<%= makale.slug %>" class="blog-read-more">Yazıyı Oku <i data-lucide="arrow-right" style="width:14px;height:14px;"></i></a>
          </div>
        </article>
        <% }); %>
      </div>
      <div class="blog-more">
        <a href="/makaleler" class="btn btn-primary"><span>Tüm Yazıları Gör</span></a>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section class="faq section" id="faq">
    <div class="container">
      <div class="faq-wrapper">
        <div class="faq-left reveal-left">
          <span class="section-tag">SSS</span>
          <h2 class="section-title gradient-text">Sık Sorulan Sorular</h2>
          <p class="section-subtitle">Diyet, beslenme ve danışmanlık süreci hakkında en çok merak edilenleri uzmanımız yanıtlıyor.</p>
          <div class="faq-cta">
            <p>Sormak istediğiniz başka bir şey var mı? Size özel beslenme planı için ücretsiz ön görüşme randevusu alabilirsiniz.</p>
            <a href="/iletisim" class="btn btn-primary"><span>Hemen Sorun</span></a>
          </div>
        </div>
        <div class="faq-right reveal-right">
          <% faq.forEach((item, i) => { %>
          <div class="faq-item <%= i === 0 ? 'active' : '' %>">
            <div class="faq-question">
              <span><%= item.question %></span>
              <i data-lucide="chevron-down" style="width:16px;height:16px;"></i>
            </div>
            <div class="faq-answer">
              <p><%= item.answer %></p>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="contact section" id="contact">
    <div class="container">
      <div class="section-header center reveal-up">
        <span class="section-tag">İletişim</span>
        <h2 class="section-title">Randevu ve <span style="color:var(--accent)">Bilgi İçin</span></h2>
        <p class="section-subtitle">Size özel beslenme programına başlamak için bizimle iletişime geçin. İlk adımı atmak çok kolay.</p>
      </div>
      <div class="contact-wrapper">
        <div class="contact-info">
          <div class="contact-card glass-card reveal-left">
            <div class="contact-card-bg"></div>
            <i data-lucide="map-pin" style="width:28px;height:28px;"></i>
            <h4>Adres</h4>
            <p><%= site.address %></p>
          </div>
          <div class="contact-card glass-card reveal-left">
            <div class="contact-card-bg"></div>
            <i data-lucide="phone" style="width:28px;height:28px;"></i>
            <h4>Telefon</h4>
            <p><%= site.phone %></p>
          </div>
          <div class="contact-card glass-card reveal-left">
            <div class="contact-card-bg"></div>
            <i data-lucide="mail" style="width:28px;height:28px;"></i>
            <h4>E-posta</h4>
            <p><%= site.email %></p>
          </div>
          <div class="contact-card glass-card reveal-left">
            <div class="contact-card-bg"></div>
            <i data-lucide="clock" style="width:28px;height:28px;"></i>
            <h4>Çalışma Saatleri</h4>
            <p><%= site.workingHours %></p>
          </div>
        </div>
        <form class="contact-form reveal-right" action="/iletisim" method="POST" novalidate>
          <div class="form-shine"></div>
          <div class="form-row">
            <div class="form-group">
              <label for="index-name" class="form-label">Adınız Soyadınız <span class="required">*</span></label>
              <input type="text" id="index-name" name="name" placeholder="Adınız Soyadınız" required minlength="2" autocomplete="name">
              <span class="form-error">Lütfen adınızı girin</span>
            </div>
            <div class="form-group">
              <label for="index-email" class="form-label">E-posta Adresiniz <span class="required">*</span></label>
              <input type="email" id="index-email" name="email" placeholder="ornek@mail.com" required autocomplete="email">
              <span class="form-error">Geçerli bir e-posta girin</span>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="index-phone" class="form-label">Telefon</label>
              <input type="tel" id="index-phone" name="phone" placeholder="0532 123 45 67" autocomplete="tel">
            </div>
            <div class="form-group">
              <label for="index-service" class="form-label">Hizmet</label>
              <select id="index-service" name="service">
                <option value="">Hizmet Seçiniz</option>
                <option>Kişisel Diyet Programı</option>
                <option>Hastalık Diyeti</option>
                <option>Gebelik Beslenmesi</option>
                <option>Sporcu Beslenmesi</option>
                <option>Detoks Programı</option>
                <option>Diğer</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="index-message" class="form-label">Mesajınız</label>
            <textarea id="index-message" name="message" rows="5" placeholder="Mesajınızı yazın..." maxlength="2000"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-block"><span>Gönder</span></button>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
