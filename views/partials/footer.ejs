            <li><i data-lucide="map-pin" style="width:16px;height:16px;"></i> <span><%= site.address %></span></li>
            <li><i data-lucide="phone" style="width:16px;height:16px;"></i> <a href="tel:<%= site.phone.replace(/[^0-9+]/g, '') %>" style="color:rgba(255,255,255,0.6)"><%= site.phone %></a></li>
            <li><i data-lucide="mail" style="width:16px;height:16px;"></i> <a href="mailto:<%= site.email %>" style="color:rgba(255,255,255,0.6)"><%= site.email %></a></li>
            <li><i data-lucide="clock" style="width:16px;height:16px;"></i> <span><%= site.workingHours %></span></li>
          </ul>
        </div>
      </div>
