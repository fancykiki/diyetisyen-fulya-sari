            <a href="https://www.facebook.com/people/Diyetisyen-Fulya-Sar%C4%B1/100089580203280/" target="_blank" rel="noopener" aria-label="Facebook"><i data-lucide="facebook" style="width:18px;height:18px;"></i></a>
