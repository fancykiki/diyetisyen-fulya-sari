<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="index, follow">
  <meta name="description" content="<%= meta.desc || site.description %>">
  <meta name="keywords" content="antalya diyetisyen, diyetisyen antalya, beslenme danışmanlığı, kilo verme, diyet programı, sağlıklı beslenme">
  <link rel="canonical" href="https://www.diyetisyenfulyasari.com<%= path %>">
  <meta property="og:title" content="<%= meta.title ? meta.title + ' | ' + site.title : site.title + ' | ' + site.subtitle %>">
  <meta property="og:description" content="<%= meta.desc || site.description %>">
  <meta property="og:url" content="https://www.diyetisyenfulyasari.com<%= path %>">
  <meta property="og:type" content="<%= meta.type || 'website' %>">
  <meta property="og:site_name" content="<%= site.title %>">
  <meta property="og:locale" content="tr_TR">
  <% if (meta.image) { %>
  <meta property="og:image" content="https://www.diyetisyenfulyasari.com/images/<%= meta.image %>">
  <% } else { %>
  <meta property="og:image" content="https://www.diyetisyenfulyasari.com/images/og-image.jpg">
  <% } %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= meta.title ? meta.title + ' | ' + site.title : site.title + ' | ' + site.subtitle %>">
  <meta name="twitter:description" content="<%= meta.desc || site.description %>">
  <% if (meta.author) { %>
  <meta name="author" content="<%= meta.author %>">
  <% } %>
  <% if (meta.date) { %>
  <meta property="article:published_time" content="<%= meta.date %>">
  <% } %>
  <% if (meta.category) { %>
  <meta property="article:section" content="<%= meta.category %>">
  <% } %>
  <title><%= meta.title ? meta.title + ' | ' + site.title : site.title + ' | ' + site.subtitle %></title>
  <script src="https://unpkg.com/lucide@0.468.0/dist/umd/lucide.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,500&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>&#x1F33F;</text></svg>">
  <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>&#x1F33F;</text></svg>">
</head>
<body>
